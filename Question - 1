Given a number n, calculate the sum of the first n natural numbers using a recursive function.

--------------------------------------------------

import java.util.Scanner;

public class Main {

    static int sum(int n) {
        if (n == 0) {
            return 0;
        }
        return n + sum(n - 1);
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        System.out.println(sum(n));
    }
}
